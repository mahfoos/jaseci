"""Grammar extraction pass tests – migrated from test_grammar_extract_pass.py.

Tests for grammar model types (GTok, GRef, GSeq, GAlt, GOpt, GStar),
EBNF/Lark formatting, simplification, and integration with the real
Jac parser module. Also validates grammar matches jac.spec.
"""

import from pathlib { Path }
import os;
import from tests.support { JAC_ROOT }
import jaclang;
import from jaclang.compiler.passes.tool.grammar_extract_pass {
    GAlt,
    GOpt,
    GPlus,
    GrammarExtractPass,
    GrammarRule,
    GRef,
    GSeq,
    GStar,
    GTok,
    MethodSemantics,
    ConditionResult,
    METHOD_TABLE,
    SPECIAL_LOOKAHEAD_TOKENS
}
import from jaclang.jac0core.program { JacProgram }

glob PARSER_PATH = str(
         Path(jaclang.__file__).parent / "jac0core" / "parser" / "parser.jac"
     ),
     SPEC_PATH = os.path.join(JAC_ROOT, "jaclang", "jac.spec");

"""Helper: format a GExpr as EBNF."""
def fmt(expr: object) -> str {
    return GrammarExtractPass.format_ebnf(None, expr);
}

"""Helper: simplify a GExpr."""
def simplify(expr: object) -> object {
    return GrammarExtractPass.simplify_expr(None, expr);
}

"""Parse EBNF text into {rule_name: rule_body} dict."""
def parse_spec(text: str) -> dict[str, str] {
    rules: dict[str, str] = {};
    current_name: str | None = None;
    current_body: str = "";
    for line in text.strip().splitlines() {
        line = line.rstrip();
        lead = line.lstrip();
        if not lead or lead.startswith("#") or lead.startswith("//") {
            continue;
        }
        if "::=" in line {
            if current_name is not None {
                rules[current_name] = " ".join(current_body.split());
            }
            (name, _, body) = line.partition("::=");
            current_name = name.strip();
            current_body = body.strip();
        } elif current_name is not None {
            stripped = line.strip();
            if stripped.startswith("| ") {
                current_body += " " + stripped;
            } else {
                current_body += " " + stripped;
            }
        }
    }
    if current_name is not None {
        rules[current_name] = " ".join(current_body.split());
    }
    return rules;
}

# ── Unit tests: grammar model and formatting ─────────────────────────────
test "gtok ebnf" {
    assert fmt(GTok(name="KW_IF")) == '"if"';
}

test "gref ebnf" {
    assert fmt(GRef(name="expression")) == "expression";
}

test "gseq ebnf" {
    seq = GSeq(items=[GTok(name="KW_IF"), GRef(name="expression")]);
    assert fmt(seq) == '"if" expression';
}

test "galt ebnf" {
    alt = GAlt(choices=[GRef(name="elif_stmt"), GRef(name="else_stmt")]);
    assert fmt(alt) == "elif_stmt | else_stmt";
}

test "gopt ebnf" {
    opt = GOpt(inner=GRef(name="else_stmt"));
    assert fmt(opt) == "else_stmt?";
}

test "gopt alt ebnf" {
    opt = GOpt(inner=GAlt(choices=[GRef(name="elif_stmt"), GRef(name="else_stmt")]));
    assert fmt(opt) == "(elif_stmt | else_stmt)?";
}

test "gstar ebnf" {
    star = GStar(inner=GSeq(items=[GTok(name="BW_OR"), GRef(name="bitwise_xor")]));
    assert fmt(star) == '("|" bitwise_xor)*';
}

test "grammar rule ebnf" {
    rule = GrammarRule(
        name="bitwise_or",
        body=GSeq(
            items=[
                GRef(name="bitwise_xor"),
                GStar(inner=GSeq(items=[GTok(name="BW_OR"), GRef(name="bitwise_xor")]))
            ]
        )
    );
    ebnf = rule.to_ebnf();
    assert ebnf == 'bitwise_or ::= bitwise_xor ("|" bitwise_xor)*';
}

test "alt inside seq gets parens" {
    seq = GSeq(items=[GTok(name="A"), GAlt(choices=[GTok(name="B"), GTok(name="C")])]);
    assert fmt(seq) == "A (B | C)";
}

test "simplify nested seq" {
    expr = GSeq(items=[GTok(name="A"), GSeq(items=[GTok(name="B"), GTok(name="C")])]);
    simplified = simplify(expr);
    assert fmt(simplified) == "A B C";
}

test "simplify single item seq" {
    expr = GSeq(items=[GTok(name="A")]);
    simplified = simplify(expr);
    assert fmt(simplified) == "A";
}

test "simplify nested alt" {
    expr = GAlt(
        choices=[GTok(name="A"), GAlt(choices=[GTok(name="B"), GTok(name="C")])]
    );
    simplified = simplify(expr);
    assert fmt(simplified) == "A | B | C";
}

test "equality" {
    assert GTok(name="X") == GTok(name="X");
    assert GRef(name="foo") == GRef(name="foo");
    assert GTok(name="X") != GTok(name="Y");
    assert GTok(name="X") != GRef(name="X");
}

test "alt collapses bare choice into optional twin" {
    expr = GAlt(choices=[GTok(name="SEMI"), GOpt(inner=GTok(name="SEMI"))]);
    assert fmt(simplify(expr)) == '";"?';
}

test "alt collapses bare choice into star twin" {
    expr = GAlt(choices=[GStar(inner=GTok(name="COMMA")), GTok(name="COMMA")]);
    assert fmt(simplify(expr)) == '","*';
}

test "opt hoist skips outer opt when a star choice exists" {
    expr = GAlt(
        choices=[GStar(inner=GTok(name="COMMA")), GOpt(inner=GTok(name="SEMI"))]
    );
    assert fmt(simplify(expr)) == '","* | ";"';
}

# ── Mini-parser fixture: behaviors of interpretation itself ──────────────
glob MINI_PARSER_SRC = """
import from jaclang.jac0core.parser.tokens { TokenKind }

obj Parser {
    def check(kind: TokenKind) -> bool { return True; }
    def match_tok(kind: TokenKind) -> bool { return True; }
    def expect(kind: TokenKind) -> int { return 0; }
    def advance -> int { return 0; }
    def flagged -> bool { return True; }
    def parse_module;
    def parse_loopy;
    def parse_optish;
    def parse_choice;
    def parse_outer;
    def parse_inner_if;
    def parse_fallback;
    def parse_rec;
    def parse_leaf;
    def parse_marker;
    def parse_marker2 -> int | None;
    def parse_maybe;
    def parse_listy;
    def parse_either;
    def parse_covered;
    def parse_wrapped;
    def parse_trying;
}

impl Parser.parse_module {
    self.parse_loopy();
    self.parse_optish();
    self.parse_choice();
    self.parse_outer();
    self.parse_rec();
    self.parse_marker();
    self.parse_maybe();
    self.parse_listy();
    self.parse_either();
    self.parse_covered();
    self.parse_trying();
}

impl Parser.parse_loopy {
    while self.match_tok(TokenKind.DOT) or self.match_tok(TokenKind.DOT_FWD) {
        self.expect(TokenKind.NAME);
    }
}

impl Parser.parse_optish {
    if self.match_tok(TokenKind.DOT) or self.match_tok(TokenKind.DOT_BKWD) {
        self.expect(TokenKind.NAME);
    }
}

impl Parser.parse_choice {
    if self.flagged() {
        self.expect(TokenKind.SEMI);
    } else {
        self.expect(TokenKind.COMMA);
    }
}

impl Parser.parse_outer {
    if self.check(TokenKind.KW_IF) {
        x = self.parse_inner_if();
        return x;
    }
    return self.parse_fallback();
}

impl Parser.parse_inner_if {
    self.expect(TokenKind.KW_IF);
    self.expect(TokenKind.NAME);
}

impl Parser.parse_fallback {
    self.expect(TokenKind.NAME);
}

impl Parser.parse_rec {
    if self.check(TokenKind.MINUS) {
        op = self.advance();
        val = self.parse_rec();
        return val;
    }
    return self.parse_leaf();
}

impl Parser.parse_leaf {
    self.expect(TokenKind.NAME);
}

impl Parser.parse_marker {
    if self.check(TokenKind.KW_OWN) {
        self.expect(TokenKind.KW_OWN);
        return;
    }
    if self.check(TokenKind.KW_IMM) {
        self.expect(TokenKind.KW_IMM);
        return;
    }
}

impl Parser.parse_marker2 -> int | None {
    if self.check(TokenKind.KW_OWN) {
        self.expect(TokenKind.KW_OWN);
        return 1;
    }
    if self.check(TokenKind.KW_IMM) {
        self.expect(TokenKind.KW_IMM);
        return 2;
    }
    return None;
}

impl Parser.parse_maybe {
    val = self.parse_leaf() if self.check(TokenKind.NAME) else None;
    self.expect(TokenKind.SEMI);
}

impl Parser.parse_listy {
    while not self.check(TokenKind.RPAREN) {
        self.parse_leaf();
        if not self.match_tok(TokenKind.COMMA) {
            break;
        }
        self.check(TokenKind.SEMI);
    }
}

impl Parser.parse_either {
    if self.check(TokenKind.KW_IF) {
        self.expect(TokenKind.KW_IF);
        return 1;
    } else {
        self.expect(TokenKind.NAME);
        return 2;
    }
}

impl Parser.parse_covered {
    if self.check(TokenKind.KW_IF) {
        x = self.parse_wrapped();
        self.expect(TokenKind.SEMI);
        return x;
    }
    return self.parse_leaf();
}

impl Parser.parse_wrapped {
    y = self.parse_inner_if();
    self.expect(TokenKind.COMMA);
}

impl Parser.parse_trying {
    m = self.parse_marker2();
    if m is not None {
        return m;
    }
    return self.parse_leaf();
}
""";

"""Compile the mini parser fixture and run extraction on it."""
def mini_pass -> GrammarExtractPass {
    import tempfile;
    with tempfile.TemporaryDirectory() as td {
        path = os.path.join(td, "mini_parser.jac");
        with open(path, "w", encoding="utf-8") as f {
            f.write(MINI_PARSER_SRC);
        }
        prog = JacProgram();
        mod = prog.compile(path, no_cgen=True);
        return GrammarExtractPass(ir_in=mod, prog=prog);
    }
}

def mini_rules -> dict {
    return {r.name: r for r in mini_pass().rules};
}

test "or merged match_tok loop emits full token set" {
    rules = mini_rules();
    assert fmt(rules["loopy"].body) == '(("." | ".>") NAME)*';
}

test "or merged match_tok opt emits full token set" {
    rules = mini_rules();
    assert fmt(rules["optish"].body) == '(("." | "<.") NAME)?';
}

test "opaque if else becomes alternation" {
    rules = mini_rules();
    assert fmt(rules["choice"].body) == '";" | ","';
}

test "guard suppressed when child rule consumes it" {
    rules = mini_rules();
    assert fmt(rules["outer"].body) == "inner_if | fallback";
}

test "self recursive guard is kept" {
    rules = mini_rules();
    assert fmt(rules["rec"].body) == '"-" rec | leaf';
}

test "genuinely nullable dispatch keeps its optionality" {
    rules = mini_rules();
    assert fmt(rules["marker"].body) == '("own" | "imm")?';
}

test "none returning dispatcher loses redundant optionality" {
    rules = mini_rules();
    assert fmt(rules["marker2"].body) == '"own" | "imm"';
}

test "ternary with none branch is optional" {
    rules = mini_rules();
    assert fmt(rules["maybe"].body) == 'leaf? ";"';
}

test "mid loop separator break emits optional separator" {
    rules = mini_rules();
    assert fmt(rules["listy"].body) == '(leaf ","?)*';
}

test "exhaustive if else chain is not optional" {
    rules = mini_rules();
    assert fmt(rules["either"].body) == '"if" | NAME';
}

test "guard covered by deep first set is elided" {
    rules = mini_rules();
    assert fmt(rules["covered"].body) == 'wrapped ";" | leaf';
}

test "try parse idiom becomes ordered choice" {
    rules = mini_rules();
    assert fmt(rules["trying"].body) == "marker2 | leaf";
}

test "strict diagnostics flag invisible constructs" {
    p = mini_pass();
    kinds = {d["kind"] for d in p.diagnostics};
    assert "bare-advance" in kinds;
    assert "unknown-method" in kinds;
    diag_text = p.emit_diagnostics();
    assert "finding" in diag_text;
    assert "flagged" in diag_text;
}

# ── Integration: extract rules from the real parser ──────────────────────
test "rules extracted" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had , f"Compilation errors: {prog.errors_had}";
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    assert len(extracted.rules) > 20 , (
        f"Expected >20 rules, got {len(extracted.rules)}"
    );
}

test "known rule names" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    rule_names = {r.name for r in extracted.rules};
    expected = {
        "if_stmt",
        "while_stmt",
        "expression",
        "bitwise_or",
        "bitwise_xor",
        "bitwise_and",
        "arithmetic",
        "term",
        "power",
        "factor"
    };
    missing = expected - rule_names;
    assert len(missing) == 0 , f"Missing rules: {missing}";
}

test "bitwise or structure" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    rule_map = {r.name: r for r in extracted.rules};
    assert "bitwise_or" in rule_map;
    ebnf = fmt(rule_map["bitwise_or"].body);
    assert "bitwise_xor" in ebnf;
    assert '"|"' in ebnf;
}

test "if stmt structure" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    rule_map = {r.name: r for r in extracted.rules};
    assert "if_stmt" in rule_map;
    ebnf = fmt(rule_map["if_stmt"].body);
    assert '"if"' in ebnf;
    assert "expression" in ebnf;
    assert '"{"' in ebnf;
    assert '"}"' in ebnf;
}

test "while stmt structure" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    rule_map = {r.name: r for r in extracted.rules};
    assert "while_stmt" in rule_map;
    ebnf = fmt(rule_map["while_stmt"].body);
    assert '"while"' in ebnf;
    assert "expression" in ebnf;
}

test "forever stmt structure" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    rule_map = {r.name: r for r in extracted.rules};
    assert "forever_stmt" in rule_map;
    ebnf = fmt(rule_map["forever_stmt"].body);
    assert '"forever"' in ebnf;
    assert "code_block_stmts" in ebnf;
    # forever has no condition and no else clause
    assert "expression" not in ebnf;
    assert "else_stmt" not in ebnf;
}

test "ebnf output nonempty" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    ebnf = extracted.emit_ebnf();
    assert len(ebnf) > 100;
    assert "::=" in ebnf;
    for line in ebnf.strip().split("\n") {
        s = line.strip();
        if not s {
            continue;
        }
        assert "::=" in line or line.startswith(" ") , f"Malformed line: {line}";
    }
}

test "no duplicate rules" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    names = [r.name for r in extracted.rules];
    assert len(names) == len(set(names)) , (
        f"Duplicate rules: {[
            n
            for n in names
            if names.count(n) > 1
        ]}"
    );
}

test "rules reference valid names" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    rule_names = {r.name for r in extracted.rules};

    def collect_refs(expr: object) -> set[str] {
        refs: set[str] = set();
        if isinstance(expr, GRef) {
            refs.add(expr.name);
        } elif isinstance(expr, GSeq) {
            for item in expr.items {
                refs.update(collect_refs(item));
            }
        } elif isinstance(expr, GAlt) {
            for choice in expr.choices {
                refs.update(collect_refs(choice));
            }
        } elif isinstance(expr, (GOpt, GStar, GPlus)) {
            refs.update(collect_refs(expr.inner));
        }
        return refs;
    }

    all_refs: set[str] = set();
    for rule in extracted.rules {
        all_refs.update(collect_refs(rule.body));
    }
    resolved = all_refs & rule_names;
    assert len(resolved) > 10 , f"Only {len(resolved)} refs resolved to known rules";
}

# ── Ratchet: strict findings may only go down ────────────────────────────
glob STRICT_FINDING_BUDGET = 37;

test "strict finding budget" {
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);
    count = len(extracted.diagnostics);
    assert count <= STRICT_FINDING_BUDGET , (
        f"grammar strict findings grew to {count} (budget {STRICT_FINDING_BUDGET}).\n"
        "New parser code consumes tokens invisibly to the grammar extractor.\n"
        "Use expect()/expect_any()/match_tok()/match_any() instead of bare "
        "advance(), keep TokenKind arguments literal, and put error recovery in "
        "_-prefixed helpers. Run `jac tool grammar --strict` to see findings.\n"
        "If you fixed findings, lower STRICT_FINDING_BUDGET to the new count."
    );
}

# ── Snapshot test: grammar matches jac.spec ──────────────────────────────
test "spec file exists" {
    spec_path = Path(SPEC_PATH);
    assert spec_path.exists() , (
        f"Grammar spec file missing: {SPEC_PATH}\n"
        f"Generate it with: jac grammar -o {SPEC_PATH}"
    );
}

test "grammar matches spec" {
    spec_path = Path(SPEC_PATH);
    if not spec_path.exists() {
        return;
    }
    prog = JacProgram();
    mod = prog.compile(PARSER_PATH, no_cgen=True);
    assert not prog.errors_had;
    extracted = GrammarExtractPass(ir_in=mod, prog=prog);

    spec_rules = parse_spec(spec_path.read_text());
    current_rules = parse_spec(extracted.emit_ebnf());

    # Check for rules in spec that disappeared
    missing = set(spec_rules) - set(current_rules);
    assert not missing , (
        f"Rules in jac.spec but no longer extracted: {missing}\n"
        f"If intentional: jac grammar -o {SPEC_PATH}"
    );

    # Check for new rules not in spec
    added = set(current_rules) - set(spec_rules);
    assert not added , (
        f"New rules not in jac.spec: {added}\n"
        f"If intentional: jac grammar -o {SPEC_PATH}"
    );

    # Check each rule body matches
    changed: list[str] = [];
    for name in sorted(spec_rules) {
        if name not in current_rules {
            continue;
        }
        if spec_rules[name] != current_rules[name] {
            changed.append(
                f"  {name}:\n    spec:    {spec_rules[name]}\n    current: {current_rules[
                    name
                ]}"
            );
        }
    }
    assert not changed , (
        f"{len(changed)} rule(s) changed:\n" + "\n".join(changed) + f"\n\nIf intentional: jac grammar -o {SPEC_PATH}"
    );
}
