"""jachammer brand logo — jacBuilder's hexagon "builder" mark, embedded as a
base64 data URI so it renders identically on web and native with no asset
staging. Used on the splash, auth screen and app header.
"""

cl {
    import from "@jac/mobui" { Image }

    glob:pub LOGO_URI = "data:image/png;base64,";

    def:pub Logo(size: int) -> JsxElement {
        return
            <Image
                source={{uri: LOGO_URI}}
                style={{width: size, height: size, borderRadius: size / 6}}
            />;
    }
}
