# Source files only - build artifacts live in .jac/mobile/

# node_modules (installed under .jac/mobile/ during build)
node_modules/

# Web bundle artifacts - regenerated by `jac build --client mobile` into
# .jac/mobile/.  create-bundle.js (the generator script) IS tracked.
assets/jac-app/bundle.html
assets/jac-app/bundle.ts
assets/jac-app/client.js
assets/jac-app/index.html
assets/jac-app/styles.css

# Placeholder icons - regenerated by `jac setup mobile` via Pillow or 1x1 fallback.
# Replace with real branded assets; do not commit generated placeholders.
assets/icon.png
assets/splash.png
assets/adaptive-icon.png
assets/favicon.png

# Native build dirs from `expo prebuild`
android/
ios/

# Environment files
.env.local
.env

# OS files
.DS_Store
*.pem
